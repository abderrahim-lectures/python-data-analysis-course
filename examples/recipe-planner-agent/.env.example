# Copy this file to .env (already gitignored) and fill in your key.
# Never commit a real key.

# github (default) -- a GitHub personal access token with the "models: read"
# scope. Free, no separate signup: https://github.com/settings/tokens
GITHUB_TOKEN=

# Using a different provider instead? See the six-provider table in
# docs/projects/recipe-planner-agent/index.md's Setup section, and swap the
# ChatOpenAI(...) block in planner.py for that provider's own client.
